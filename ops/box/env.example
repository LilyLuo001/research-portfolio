# L1 API keys — copy to ops/box/.env (git-ignored) and fill in what you have.
# These live ONLY on the always-on box. NEVER commit real keys; NEVER put a
# Claude/Anthropic subscription token here (that path is not compliant — see
# ops/COMPLIANCE.md). Leave a line blank and that worker simply stays dry-run.

DEEPSEEK_API_KEY=      # DeepSeek reasoning + standard code (L1 workhorse)
KIMI_API_KEY=          # Moonshot Kimi + $web_search (long-doc extraction, facts)
GLM_API_KEY=           # Zhipu GLM (2nd code stack / bulk / 中文)
QWEN_API_KEY=          # Alibaba Qwen (cheapest adequate bulk annotation)
GEMINI_API_KEY=        # Google Gemini Flash free tier (¥0 cross-vendor channel B)
