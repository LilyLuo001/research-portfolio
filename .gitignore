__pycache__/
*.pyc
.pytest_cache/
.venv/

# box-only secrets + runtime logs (never leave the always-on box)
ops/box/.env
ops/box/cron.log
ops/runner/spend_log.jsonl
# L1 batch outputs — raw extraction, produced on the box
ops/l1/out/
# NOTE: ops/runner/state.json is deliberately TRACKED, not ignored — completion
# and gate state must be visible to every seat's clone (the repo is the only
# shared state), or a fresh seat re-assigns finished tasks. Only spend logs and
# secrets stay box-local.
